#!/usr/bin/env python3
"""Verify the install tiers resolve and guard correctly.

Builds throwaway venvs and runs smoke checks inside each:
  1. bare `pip install pf-core` (no extras) -> bin/bare_install_smoke.py
       - foundation (+ stdlib/pyyaml llm members) import on five base deps,
       - httpx / pydantic / json-repair / tenacity / typer absent,
       - parse/validate guard to [validate], clients to [llm], url utils to [http].
  2. `pip install pf-core[validate]` -> bin/validate_install_smoke.py
       - anti-slop guards (parse + validate) import with NO client/HTTP stack,
       - clients still guard to [llm], tracked to [tracking].

Run from anywhere:
    python bin/verify-bare-install

Exit codes:
    0 -- all phases lean and guards fire correctly
    1 -- a smoke check failed
    2 -- venv creation or install failed
"""

from __future__ import annotations

import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

REPO = Path(__file__).resolve().parents[1]

# (label, install spec relative to REPO, smoke script)
PHASES = [
    ("bare (no extras)", str(REPO), REPO / "bin" / "bare_install_smoke.py"),
    ("[validate]", f"{REPO}[validate]", REPO / "bin" / "validate_install_smoke.py"),
]


def _base_python() -> str | None:
    """A Python >=3.11 to build the venv with (pf-core's floor)."""
    if sys.version_info >= (3, 11):
        return sys.executable
    for name in ("python3.13", "python3.12", "python3.11"):
        found = shutil.which(name)
        if found:
            return found
    return None


def _run_phase(base_py: str, label: str, spec: str, smoke: Path) -> int:
    """Build a fresh venv, install `spec`, run `smoke`. Returns 0/1/2."""
    with tempfile.TemporaryDirectory(prefix="pfverify-") as tmp:
        venv = Path(tmp) / "venv"
        py = venv / "bin" / "python"

        print(f"\n=== Phase: {label} ===")
        print(f"Creating throwaway venv at {venv} (base: {base_py}) ...")
        if subprocess.run([base_py, "-m", "venv", str(venv)]).returncode:
            print("ERROR: venv creation failed", file=sys.stderr)
            return 2

        print(f"Installing {spec} ...")
        if subprocess.run([str(py), "-m", "pip", "install", "--quiet", spec]).returncode:
            print(f"ERROR: install of {spec} failed", file=sys.stderr)
            return 2

        print("Running smoke checks ...\n")
        # cwd=tmp so `import pf_core` resolves to the installed copy, never the
        # source tree under REPO/src.
        return 1 if subprocess.run([str(py), str(smoke)], cwd=tmp).returncode else 0


def main() -> int:
    base_py = _base_python()
    if base_py is None:
        print("ERROR: need Python >=3.11 to build the verification venvs", file=sys.stderr)
        return 2

    worst = 0
    for label, spec, smoke in PHASES:
        rc = _run_phase(base_py, label, spec, smoke)
        worst = max(worst, rc)
    return worst


if __name__ == "__main__":
    sys.exit(main())
