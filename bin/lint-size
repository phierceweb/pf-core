#!/usr/bin/env python3
"""Check Python file sizes against per-layer limits.

Run from a consumer project root:
    python ../pf-core/bin/lint-size

Exit codes:
    0 -- all files within limits
    1 -- files over limit found
    2 -- no app/ directory found
"""

import sys
from pathlib import Path

# Default limits by top-level app/ subdirectory
DIR_LIMITS = {
    "cli": 100,
    "services": 300,
    "repo": 300,
    "api": 300,
    "orchestrators": 400,
}
DEFAULT_LIMIT = 500
UTIL_LIMIT = 150

try:
    import yaml
except ImportError:
    yaml = None


def load_config() -> tuple[set[str], dict[str, int]]:
    """Load exemptions + per-path limit overrides from .lint-size.yaml.

    YAML shape::

        limits:
          app/cli: 400         # keys are path prefixes under the project root
          app/services: 500
        exempt:
          - app/db/sections.py

    Returns:
        (exempt_paths, limit_overrides) — the second dict maps path-prefix
        strings (``"app/cli"``) to integer line limits. Longer prefixes win
        when multiple match.
    """
    config_path = Path(".lint-size.yaml")
    if not config_path.exists():
        return set(), {}
    if yaml is None:
        print(
            "Warning: .lint-size.yaml found but PyYAML not installed; ignoring.",
            file=sys.stderr,
        )
        return set(), {}
    try:
        data = yaml.safe_load(config_path.read_text()) or {}
    except Exception as exc:
        print(f"Warning: failed to parse .lint-size.yaml: {exc}", file=sys.stderr)
        return set(), {}

    exempt: set[str] = set()
    if isinstance(data.get("exempt"), list):
        exempt = {str(Path(p)) for p in data["exempt"]}

    limits: dict[str, int] = {}
    raw_limits = data.get("limits")
    if isinstance(raw_limits, dict):
        for k, v in raw_limits.items():
            try:
                limits[str(Path(k))] = int(v)
            except (TypeError, ValueError):
                print(
                    f"Warning: ignoring non-integer limit for {k!r}: {v!r}",
                    file=sys.stderr,
                )

    return exempt, limits


def limit_for(path: Path, overrides: dict[str, int]) -> int:
    """Determine the line limit for a file, honouring YAML overrides.

    Override match order (longest prefix wins):
        1. Any key in ``overrides`` whose value is a path prefix of *path*.
        2. Built-in defaults below.
    """
    path_str = str(path)

    if overrides:
        matching = [
            (prefix, cap)
            for prefix, cap in overrides.items()
            if path_str == prefix or path_str.startswith(prefix.rstrip("/") + "/")
        ]
        if matching:
            matching.sort(key=lambda kv: len(kv[0]), reverse=True)
            return matching[0][1]

    if path.name.startswith("_util"):
        return UTIL_LIMIT

    # Check top-level subdirectory under app/
    parts = path.parts  # e.g. ("app", "services", "grading.py")
    if len(parts) >= 2:
        subdir = parts[1]
        if subdir in DIR_LIMITS:
            return DIR_LIMITS[subdir]
    return DEFAULT_LIMIT


def main() -> int:
    app_dir = Path("app")
    if not app_dir.is_dir():
        print("Error: no app/ directory found in current directory.")
        return 2

    exempt, overrides = load_config()
    violations = []

    for py_file in sorted(app_dir.rglob("*.py")):
        rel = str(py_file)
        if rel in exempt:
            continue
        line_count = len(py_file.read_text().splitlines())
        limit = limit_for(py_file, overrides)
        if line_count > limit:
            violations.append((rel, line_count, limit))

    if not violations:
        print("All files within size limits.")
        return 0

    # Sort by most over limit first
    violations.sort(key=lambda v: v[1] - v[2], reverse=True)

    for rel, count, limit in violations:
        over = count - limit
        print(f"OVER LIMIT: {rel}")
        print(f"  {count} lines (limit: {limit}, over by {over})")
        print()

    print(f"Found {len(violations)} file(s) over their size limit.")
    return 1


if __name__ == "__main__":
    sys.exit(main())
