# ─── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# ─── Virtual environments ──────────────────────────────────────────────────
.venv/
venv/

# ─── Secrets & environment ─────────────────────────────────────────────────
.env

# ─── Databases ─────────────────────────────────────────────────────────────
*.db
*.sqlite

# ─── Logs ──────────────────────────────────────────────────────────────────
logs/

# ─── OS & editor cruft ─────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/

# ─── AI / agent workspace ──────────────────────────────────────────────────
# .ai/docs/, .ai/plans/, .ai/reviews/, .ai/scripts/, .ai/skills/ are local-only working docs.
# Tracked: .ai/rules/ (project conventions, useful to contributors) + .gitkeep
# markers.
.ai/docs/*
!.ai/docs/.gitkeep
.ai/plans/*
!.ai/plans/.gitkeep
.ai/reviews/*
.ai/scripts/*
!.ai/scripts/.gitkeep
.ai/skills/*
!.ai/skills/.gitkeep

# ─── Claude Code local-only state ──────────────────────────────────────────
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/
