#!/usr/bin/env bash
# Bootstrap __NAME__: venv (Python 3.11+), editable install, .env, rule symlinks.
# Self-contained — works whether pf-core is pip-installed or a sibling checkout.
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
ok()   { echo "  ✓ $*"; }
info() { echo "  $*"; }

pick_python() {
  local p
  for p in python3.13 python3.12 python3.11 python3; do
    p="$(command -v "$p" 2>/dev/null || true)"
    [[ -n "$p" ]] || continue
    if "$p" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' 2>/dev/null; then
      echo "$p"; return 0
    fi
  done
  echo "No Python 3.11+ found. Install 3.11+ (e.g. brew install python@3.12)." >&2
  exit 1
}

if [[ ! -d .venv ]]; then
  PY="$(pick_python)"
  info "Creating .venv ($("$PY" --version | tr -d '\r'))"
  "$PY" -m venv .venv
  ok ".venv created"
else
  ok ".venv exists ($(.venv/bin/python --version | tr -d '\r'))"
fi

info "Installing (editable, with dev extras) — the pf-core git clone can take ~30s..."
.venv/bin/python -m pip install --quiet --upgrade pip
GIT_TERMINAL_PROMPT=0 .venv/bin/python -m pip install -e ".[dev]"
ok "dependencies installed"

if [[ -f .env.example && ! -f .env ]]; then
  cp .env.example .env
  ok "copied .env.example -> .env"
fi

for tool in .claude .cursor; do
  mkdir -p "$tool"
  for d in rules skills; do
    [[ -e "$ROOT/.ai/$d" ]] || continue
    rm -rf "${tool:?}/$d"
    ln -s "../.ai/$d" "$tool/$d"
    ok "$tool/$d -> ../.ai/$d"
  done
done

# Link pf-core's module docs where assistants look. Re-resolves every run, so
# venv rebuilds and editable-vs-wheel installs both stay correct.
PF_DOCS="$(.venv/bin/python -c 'import pf_core, pathlib; print(pathlib.Path(pf_core.__file__).parent / "docs")' 2>/dev/null || true)"
if [[ -n "$PF_DOCS" && -d "$PF_DOCS" ]]; then
  mkdir -p docs
  ln -sfn "$PF_DOCS" docs/pf-core
  ok "docs/pf-core -> $PF_DOCS"
fi

# Ensure the structural-gate config exists (stamped by the scaffold; self-heals).
if [[ ! -f .pf-guards.toml ]]; then
  printf '[tool.pf_guards]\nroot = "app"\n' > .pf-guards.toml
  ok "created .pf-guards.toml"
fi

# Install the commit gates (structural gate + ruff) when this is a git repo.
if [[ -d .git && -x .venv/bin/pre-commit ]]; then
  .venv/bin/pre-commit install >/dev/null
  ok "pre-commit hooks installed (gate runs on every commit)"
else
  info "not a git repo yet — run 'git init && .venv/bin/pre-commit install' to enable the commit gates"
fi

echo
echo "Setup complete. Try: bin/web   (then open http://127.0.0.1:8000/)"
